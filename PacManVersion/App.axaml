<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PacManVersion.App">
    <Application.DataTemplates>
        <local:ViewLocator xmlns:local="clr-namespace:PacManVersion"/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <local:MultiplyConverter xmlns:local="clr-namespace:PacManVersion" x:Key="MultiplyConverter" />
    </Application.Resources>
</Application>